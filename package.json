{
  "name": "my-clip-factory",
  "version": "1.0.0",
  "private": true,
  "description": "Local-first livestream clipping factory with Next.js, Remotion, and SQLite",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jainam-ranka/my-clip-factory.git"
  },
  "keywords": [
    "livestream",
    "video",
    "clips",
    "remotion",
    "whisper",
    "openai",
    "nextjs"
  ],
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "tsc --noEmit --incremental false -p tsconfig.lint.json",
    "telegram:bot": "node --env-file=.env.local --import tsx scripts/telegram-bot.ts",
    "remotion:studio": "remotion studio src/remotion/index.ts",
    "remotion:render": "remotion render src/remotion/index.ts LiveClipComposition"
  },
  "dependencies": {
    "@remotion/captions": "4.0.464",
    "@remotion/cli": "4.0.464",
    "@remotion/google-fonts": "4.0.464",
    "googleapis": "^171.4.0",
    "next": "16.2.6",
    "openai": "^6.7.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "remotion": "4.0.464",
    "zod": "^4.1.12"
  },
  "overrides": {
    "postcss": "8.5.10"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
